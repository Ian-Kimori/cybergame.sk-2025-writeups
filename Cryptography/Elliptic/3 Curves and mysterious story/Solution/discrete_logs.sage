# --- the full-order points you found ---
P1 = E1(22395872758287743699464164679279242864, 118251808429504440787405524361972551829)
P2 = E2(333479344093653429989255083264496625, 179504395241003646309131647897099514926)
P3 = E3(205510834011027452158477939779569635549, 36396889933712338694788031561093669014)

