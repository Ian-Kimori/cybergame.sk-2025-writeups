# --- Paste your values here: ---
n = ZZ()
e = 65537

# From the printed `enc = … + B*i + C*j + D*k`:
b_enc = ZZ()
c_enc = ZZ()
d_enc = ZZ()
# -------------------------------

# Build the 3×3 system matrix over Zmod(n):
M = Matrix(Zmod(n), [
    [ 3*(c_enc - b_enc),      (c_enc - 13*b_enc),      (337*c_enc -  37*b_enc) ],
    [ 3*d_enc - 7*b_enc,      (d_enc -133*b_enc),      (337*d_enc -   7*b_enc) ],
    [ 3*d_enc - 7*c_enc,      (13*d_enc -133*c_enc),   ( 37*d_enc -   7*c_enc) ]
])

# Compute Smith Normal Form over the integers to extract a kernel basis mod n
MZZ = Matrix(ZZ, M)
(D,U,V) = MZZ.smith_form()
# The kernel mod n is generated by the third column of V
v_int = V.column(2)
# Lift out integer representatives modulo n
x, y, z = [Integer(v_int[i] % n) for i in range(3)]

# Recover q = gcd(z,n), then p = n//q:
q = gcd(z, n)
p = n // q

# The kernel vector is (x,y,z) ≡ k·(m,p,q) mod n.
# So z ≡ k·q (mod n) ⇒ k ≡ z//q  in Z  (since 0 ≤ z < n)
k = Integer(z // q)

# Finally recover m ≡ x/k (mod p), and turn into bytes
m = Integer( (x * inverse_mod(k, p)) % p )
flag = m.to_bytes((m.bit_length()+7)//8, 'big')

print(flag)    # ← voilà, the flag!